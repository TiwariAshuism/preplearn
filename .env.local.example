# ── Local development (optional — only needed to sync from Notion) ──
NOTION_API_KEY=secret_xxx
NOTION_ROOT_PAGE_ID=your-root-page-id

# Skip Notion API during build (recommended on Vercel when content/ is committed)
# SKIP_NOTION_FETCH=1

# Fail build on broken internal links (default: warn only)
# CHECK_LINKS_STRICT=1

# ── Vercel project settings ──
# Add the same vars in: Project → Settings → Environment Variables
#   NOTION_API_KEY          → Production only (optional if content is in git)
#   NOTION_ROOT_PAGE_ID     → Production only (optional)
#   SKIP_NOTION_FETCH=1     → Production (recommended — faster builds, uses git content)
#
# Do NOT expose NOTION_* to the browser — they are build-time only (prebuild script).
#
# Vercel auto-detects Next.js + bun.lock. vercel.json sets install/build commands.
# Deploy: connect repo → Import → Deploy (no extra config required).
