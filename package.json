    "vercel-build": "bun run build"
  },
  "dependencies": {
    "@notionhq/client": "^5.22.0",
    "feed": "^5.2.1",
    "gray-matter": "^4.0.3",
    "idb": "^8.0.3",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "next-sitemap": "^4.2.3",
    "notion-to-md": "^3.1.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-shiki": "^0.0.9",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
